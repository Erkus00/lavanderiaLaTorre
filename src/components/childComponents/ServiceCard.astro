---
interface Props {
    name: string;
    description: string;
    images: readonly string[];
}

const {name, description, images} = Astro.props;
---

<!--<div class="card w-full bg-base-100 border-r-1 border-primary border-b-2 border-l-1  lg:max-w-[75%] ml-auto mr-auto mb-10">-->
<div class="card w-full bg-background  border-primary border-b-2">
    <div class="card-body p-5 2xl:p-8">
        <h2 class="text-sans-title text-center text-lg md:text-xl 2xl:text-2xl text-primary font-bold w-full mb-5">{name}</h2>
        <div class="w-full hidden xl:grid">
            <figure class="auto-gallery  grid laptop:h-60 2xl:h-72 w-auto">
                {images.map((img, i) => (
                        <img
                                class="laptop:h-60 2xl:h-72 object-cover col-start-1 row-start-1 transition-opacity duration-700 w-full rounded-box shadow-sm"
                                class:list={[i === 0 ? "opacity-100" : "opacity-0"]}
                                src={img}
                                alt={`${name} - imagen ${i + 1}`}
                                data-astro-skip
                                loading={i === 0 ? "eager" : "lazy"}
                                decoding="async"
                                width="400"
                                height="300"
                        />
                ))}
            </figure>
        </div>
        <div class="carousel carousel-center rounded-box p-2 xl:hidden gap-4">
            {images.map((img, i) => (
                    <div class="carousel-item w-full justify-center">
                        <img
                                src={img}
                                class="rounded-box h-72 object-cover"
                                alt={`${name} - imagen ${i + 1}`}
                                data-astro-skip
                                loading={i === 0 ? "eager" : "lazy"}
                                decoding="async"
                                width="400"
                                height="300"
                        />
                    </div>
            ))}
        </div>

        <div class="mt-2">
            <div class="divider h-px bg-gradient-to-r from-transparent via-primary/90 to-transparent"></div>
            <p class="text-sm md:text-base ps-3">{description}</p>
            <div class="divider h-px bg-gradient-to-r from-transparent via-primary/90 to-transparent"></div>

        </div>
    </div>
</div>

<script>
    document.querySelectorAll('.auto-gallery').forEach((gallery, index) => {
        const imgs = gallery.querySelectorAll('img');
        if (imgs.length < 2) return;
        let current = 0;
        setTimeout(() => {
            setInterval(() => {
                imgs[current].classList.replace('opacity-100', 'opacity-0');
                current = (current + 1) % imgs.length;
                imgs[current].classList.replace('opacity-0', 'opacity-100');
            }, 5000);
        }, index * 2500);
    });
</script>
