---
import {business} from "../data/business";

const currentYear = new Date().getFullYear();
---

<footer
        class="text-latorre-text bg-latorre-background"
        role="contentinfo"
>
    <div class="container mx-auto px-4 py-12">
        <div class="flex flex-wrap justify-around gap-8">

            <div class="w-full md:w-[35%]">
                <a
                        href="/"
                        class="font-stencil text-2xl text-latorre-primary"
                        aria-label="Lavandería La Torre - Ir al inicio"
                >
                    LA TORRE
                </a>
                <p class="mt-4 text-latorre-silver text-sm leading-relaxed">
                    Lavandería y tintorería a domicilio. Servicio rápido, eficiente y de alta calidad para empresas y particulares.
                </p>

                <nav class="flex flex-wrap gap-x-4 gap-y-1 mt-4" aria-label="Servicios principales">
                    {business.services.map((servicio) => (
                            <a
                                    href="#servicios"
                                    class="text-latorre-text hover:text-latorre-primary transition-colors text-sm"
                            >
                                {servicio.name}
                            </a>
                    ))}
                </nav>
            </div>

            <div class="w-full md:w-[25%]">
                <h3 class="font-stencil text-lg text-latorre-text mb-4">Cobertura</h3>
                <div
                        class="grid grid-cols-2 gap-2"
                        role="list"
                        aria-label="Zonas de servicio"
                >
                    {business.areaServed.map((zona) => (
                            <span
                                    class="text-latorre-silver text-sm"
                                    role="listitem"
                            >
                            {zona.name}
                        </span>
                    ))}
                </div>
            </div>

            <div class="w-full md:w-[20%]">
                <h3 class="font-stencil text-lg text-latorre-text mb-4">Contacto</h3>
                <address class="not-italic">
                    <ul class="space-y-3" role="list">
                        <li>
                            <a
                                    href={`https://wa.me/${business.whatsapp}`}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="flex items-center gap-2 text-latorre-silver hover:text-latorre-primary transition-colors text-sm"
                                    aria-label="Contactar por WhatsApp"
                            >
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                                </svg>
                                WhatsApp
                            </a>
                        </li>
                        <li>
                            <a
                                    href={`mailto:${business.email}`}
                                    class="flex items-center gap-2 text-latorre-silver hover:text-latorre-primary transition-colors text-sm"
                                    aria-label="Enviar email"
                            >
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                                </svg>
                                Email
                            </a>
                        </li>
                    </ul>
                </address>
            </div>

        </div>

        <div class="border-t border-latorre-silver/20 mt-10 pt-6 flex px-[5%] flex-col sm:flex-row justify-between items-center gap-4 w-full">
            <p class="text-latorre-silver text-sm">
                © {currentYear} Lavandería La Torre
            </p>
            <a href="mailto:sellmanbsn@proton.me" class="text-latorre-silver text-sm hover:text-latorre-primary transition-colors">
                Desarrollado por Carlos Aragón
            </a>
            <nav class="flex gap-4 text-sm" aria-label="Enlaces legales">
                <a href="/aviso_legal" class="text-latorre-silver hover:text-latorre-primary transition-colors">
                    Aviso legal
                </a>
                <a href="/privacidad" class="text-latorre-silver hover:text-latorre-primary transition-colors">
                    Privacidad
                </a>
            </nav>
        </div>

    </div>
</footer>
