---
import { business } from "../data/business";
---

<section id="contacto" class="bg-base-200 py-16 px-4">
    <div class="max-w-4xl mx-auto">

        <!-- Header -->
        <div class="text-center mb-16">
            <h2
                    id="contacto-titulo"
                    class="font-stencil text-3xl md:text-4xl lg:text-5xl text-latorre-text mb-4"
            >
                Contáctanos
            </h2>
            <p class="text-latorre-text/70 text-lg max-w-2xl mx-auto">
                Estamos aquí para ayudarte
            </p>
        </div>

        <div class="grid md:grid-cols-5 gap-8">

            <!-- Info de contacto -->
            <div class="md:col-span-2 space-y-4">

                <!-- Ubicación -->
                <div class="card bg-base-100 shadow-sm">
                    <div class="card-body p-4 flex-row items-center gap-4">
                        <div class="btn btn-circle btn-primary btn-sm">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                        </div>
                        <div>
                            <p class="font-semibold text-sm">Dirección</p>
                            <p class="text-xs text-base-content/60">{business.address.street}</p>
                        </div>
                    </div>
                </div>

                <!-- Teléfono -->
                <div class="card bg-base-100 shadow-sm">
                    <div class="card-body p-4 flex-row items-center gap-4">
                        <div class="btn btn-circle btn-primary btn-sm">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                            </svg>
                        </div>
                        <div>
                            <p class="font-semibold text-sm">Teléfono</p>
                            <a href="tel:+34912345678" class="text-xs link link-primary">{business.phone}</a>
                        </div>
                    </div>
                </div>

                <!-- Horario -->
                <div class="card bg-base-100 shadow-sm">
                    <div class="card-body p-4 flex-row items-center gap-4">
                        <div class="btn btn-circle btn-primary btn-sm">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                        </div>
                        <div>
                            <p class="font-semibold text-sm">Horario</p>
                            <p class="text-xs text-base-content/60">{business.openingHoursText.weekdays} | {business.openingHoursText.saturday}</p>
                        </div>
                    </div>
                </div>

                <!-- WhatsApp -->
                <a href=`https://wa.me/${business.whatsapp}` target="_blank" class="btn btn-success btn-block gap-2">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                    </svg>
                    WhatsApp
                </a>
            </div>

            <!-- Formulario -->
            <div class="md:col-span-3">
                <div class="card bg-base-100 shadow-sm">
                    <div class="card-body">

                        <form id="contact-form" class="space-y-4">

                            <!-- Nombre y Teléfono -->
                            <div class="grid sm:grid-cols-2 gap-4">
                                <div class="form-control">
                                    <label class="label">
                                        <span class="label-text">Nombre</span>
                                    </label>
                                    <input type="text" name="nombre" placeholder="Tu nombre" class="input input-bordered" required/>
                                </div>

                                <div class="form-control">
                                    <label class="label">
                                        <span class="label-text">Teléfono</span>
                                    </label>
                                    <input type="tel" name="telefono" placeholder="+34 600 000 000" class="input input-bordered"/>
                                </div>
                            </div>

                            <!-- Email -->
                            <div class="form-control">
                                <label class="label">
                                    <span class="label-text">Email</span>
                                </label>
                                <input type="email" name="email" placeholder="tu@email.com" class="input input-bordered" required/>
                            </div>

                            <!-- Servicio -->
                            <div class="form-control">
                                <label class="label">
                                    <span class="label-text">Servicio</span>
                                </label>
                                <select name="servicio" class="select select-bordered">
                                    <option disabled selected>Selecciona un servicio</option>
                                    <option value="lavado">Lavado y secado</option>
                                    <option value="planchado">Planchado</option>
                                    <option value="tintoreria">Tintorería</option>
                                    <option value="edredones">Edredones y mantas</option>
                                    <option value="empresas">Servicio empresas</option>
                                    <option value="otro">Otro</option>
                                </select>
                            </div>

                            <!-- Mensaje -->
                            <div class="form-control">
                                <label class="label">
                                    <span class="label-text">Mensaje</span>
                                </label>
                                <textarea name="mensaje" class="textarea textarea-bordered" rows="3" placeholder="¿En qué podemos ayudarte?" required></textarea>
                            </div>

                            <!-- Privacidad -->
                            <div class="form-control">
                                <label class="label cursor-pointer justify-start gap-3">
                                    <input type="checkbox" name="privacidad" class="checkbox checkbox-primary checkbox-sm" required/>
                                    <span class="label-text text-xs">Acepto la <a href="/privacidad" class="link link-primary">política de privacidad</a></span>
                                </label>
                            </div>

                            <!-- Enviar -->
                            <button type="submit" class="btn btn-primary btn-block">
                                Enviar mensaje
                            </button>

                        </form>

                    </div>
                </div>
            </div>

        </div>
    </div>
</section>
