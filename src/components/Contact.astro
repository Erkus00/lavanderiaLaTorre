---
import {business} from "../data/business";
import Title from "./childComponents/Title.astro";
---

<section id="contacto" class="py-10 bg-latorre-background px-[5%]">
    <div class="container mx-auto px-4">

        <Title text="Contáctanos" id="contacto-titulo"/>

        <div class="grid grid-cols-1 md:grid-cols-5 gap-8">
            <div id="contact-form" class="md:col-span-3 ">
                <div class=" w-full md:mx-0 md:ms-5">
                    <form id="contactForm" action="https://api.web3forms.com/submit" method="POST" class="p-4 bg-transparent">

                        <input type="hidden" name="access_key" value="ea41b90e-2104-4009-a5ca-f32e38d5fd73"/>

                        <input type="hidden" name="subject" value="Nueva consulta - Lavandería La Torre"/>
                        <input type="hidden" name="from_name" value="Lavandería La Torre Web"/>

                        <fieldset class="fieldset form-control text-neutral">
                            <legend class="fieldset-legend">¿Cuál es su nombre?</legend>
                            <input type="text" name="nombre" placeholder="Nombre" class="input input-primary"/>
                        </fieldset>

                        <fieldset class="fieldset form-control text-neutral">
                            <legend class="fieldset-legend">¿Cuál es su email?</legend>
                            <label class="input validator input-primary text-neutral">
                                <span class="sr-only">Email</span>
                                <svg class="h-[1em] opacity-50" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                                    <g stroke-linejoin="round" stroke-linecap="round" stroke-width="2.5" fill="none" stroke="currentColor">
                                        <rect width="20" height="16" x="2" y="4" rx="2"></rect>
                                        <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
                                    </g>
                                </svg>
                                <input type="email" name="email" placeholder="mail@site.com"/>
                            </label>
                            <div class="validator-hint hidden">Ingrese un email válido</div>
                        </fieldset>

                        <fieldset class="fieldset form-control text-neutral">
                            <legend class="fieldset-legend">¿En qué podemos asesorarte?</legend>
                            <textarea name="mensaje" class="textarea textarea-primary w-full" placeholder="Tu mensaje..." rows="3"></textarea>
                        </fieldset>

                        <button type="submit" class="flex btn btn-primary w-auto ml-auto mt-10" disabled>
                            Enviar
                        </button>
                    </form>
                </div>

            </div>

            <div class="md:col-span-2 space-y-4 bg-transparent">

                    <div class="space-y-3 lg:flex lg:gap-3 justify-around ">

                        <div>
                            <p class="font-semibold text-base-content/60 text-sm">Dirección</p>
                            <p class=" font-semibold text-xs mt-2">{business.address.street}</p>
                        </div>
                        <div>
                            <p class="font-semibold text-base-content/60 text-sm">Teléfono</p>
                            <p class="font-semibold text-xs mt-2">{business.phone}</p>
                        </div>
                        <div>
                            <p class="font-semibold text-base-content/60 text-sm">Horario</p>
                            <p class="font-semibold text-xs mt-2">{business.openingHoursText.weekdays} | {business.openingHoursText.saturday}</p>
                        </div>
                    </div>

                <div class="space-y-3 lg:flex lg:gap-3 justify-around">
                    <a href=`https://wa.me/${business.whatsapp}` target="_blank" class="btn btn-success btn-block lg:w-2/5">
                        <svg class="w-5 h-5" fill="white" viewBox="0 0 24 24">
                            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                        </svg>
                        <p class="text-white">
                            WhatsApp

                        </p>
                    </a>

                    <a href=`mailto:${business.email}` class="btn btn-primary btn-block lg:w-3/5">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="2" y="4" width="20" height="16" rx="2"/>
                            <path d="M22 6L12 13L2 6"/>
                        </svg>
                        Correo electrónico
                    </a>
                </div>
            </div>


        </div>
    </div>

    <script>
        const form = document.getElementById('contactForm') as HTMLFormElement;
        const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
        const nombre = form.querySelector('input[name="nombre"]') as HTMLInputElement;
        const email = form.querySelector('input[name="email"]') as HTMLInputElement;
        const mensaje = form.querySelector('textarea[name="mensaje"]') as HTMLTextAreaElement;

        form.reset();

        function validar() {
            const emailValido = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value);
            const valido = nombre.value.trim() && emailValido && mensaje.value.trim();
            btn.disabled = !valido;
        }

        [nombre, email, mensaje].forEach(el => el.addEventListener('input', validar));

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            btn.disabled = true;
            btn.textContent = 'Enviando...';

            try {
                const res = await fetch('https://api.web3forms.com/submit', {
                    method: 'POST',
                    body: new FormData(form),
                } as any);
                const data = await res.json();

                if (data.success) {
                    form.reset();
                    btn.textContent = 'Enviado correctamente';
                    btn.classList.remove('btn-primary');
                    btn.classList.add('btn-success');
                    setTimeout(() => {
                        btn.textContent = 'Enviar';
                        btn.classList.remove('btn-success');
                        btn.classList.add('btn-primary');
                        btn.disabled = true;
                    }, 4000);
                } else {
                    throw new Error('Error en el envío');
                }
            } catch {
                btn.textContent = '✗ Error al enviar';
                btn.classList.remove('btn-primary');
                btn.classList.add('btn-error');
                setTimeout(() => {
                    btn.textContent = 'Enviar';
                    btn.classList.remove('btn-error');
                    btn.classList.add('btn-primary');
                    validar();
                }, 4000);
            }
        });
    </script>
</section>



