---
import {business} from "../data/business";
import ServiceCard from "./childComponents/ServiceCard.astro";
---

<section
        id="servicios"
        class="py-10 bg-latorre-background"
        aria-labelledby="servicios-titulo"
>
    <div class="container mx-auto px-4">

        <div class="text-center mb-4 w-full flex">
            <h2
                    id="servicios-titulo"
                    class="w-1/3 font-stencil text-3xl md:text-4xl lg:text-5xl text-latorre-text mb-4"
            >
                Nuestros Servicios
            </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-8">
            {business.services.map((servicio) => (
                    <ServiceCard
                            name={servicio.name}
                            description={servicio.description}
                            images={servicio.images}
                            featured={servicio.featured}
                    />
            ))}
        </div>

    </div>
</section>
