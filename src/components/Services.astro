---
import {business} from "../data/business";
import ServiceCard from "./childComponents/ServiceCard.astro";
---

<section
        id="servicios"
        class="py-20 bg-latorre-background"
        aria-labelledby="servicios-titulo"
>
    <div class="container mx-auto px-4">

        <div class="text-center mb-16">
            <h2
                    id="servicios-titulo"
                    class="font-stencil text-3xl md:text-4xl lg:text-5xl text-latorre-text mb-4"
            >
                Nuestros Servicios
            </h2>
            <p class="text-latorre-text/70 text-lg max-w-2xl mx-auto">
                Soluciones profesionales de lavandería y tintorería adaptadas a cada necesidad
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-50 gap-y-8 w-fit mx-auto">
            {business.services.map((servicio) => (
                    <ServiceCard
                            name={servicio.name}
                            description={servicio.description}
                            images={servicio.images}
                            featured={servicio.featured}
                    />
            ))}
        </div>

    </div>
</section>
