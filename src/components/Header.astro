---
const navLinks = [
    {name: 'Inicio', href: '/'},
    {name: 'Servicios', href: '#servicios'},
    {name: 'Cobertura', href: '#zonas'}
];

import {business} from "../data/business";
---

<header
        class="bg-latorre-base sticky top-0 z-50 shadow-[0_2px_4px_0_rgba(0,0,0,0.05)]"
        role="banner"
>
    <div class="container mx-auto px-4">
        <nav
                class="navbar min-h-16"
                role="navigation"
                aria-label="Navegación principal"
        >

            <div class="navbar-start">
                <a
                        href="/"
                        class="font-stencil text-2xl text-latorre-primary animate-fade-in-left animate-duration-500 flex items-center gap-3"
                        aria-label="Lavandería La Torre - Ir al inicio"
                >
                    <div class="w-10 h-10 rounded-full bg-white overflow-hidden">
                        <img src={business.logo} alt="" class="w-full h-full object-cover" data-astro-skip loading="lazy" width="400" height="300"/>
                    </div>
                    <span>LA TORRE</span>
                </a>
            </div>

            <div class="mt-3 navbar-center hidden lg:flex">
                <ul class="menu menu-horizontal gap-10" role="menubar">
                    {navLinks.map((link) => (
                            <li role="none">
                                <a
                                        href={link.href}
                                        class="relative text-md text-latorre-text hover:text-latorre-primary hover:bg-latorre-base hover:scale-120 transition-all duration-300 after:absolute  "
                                        role="menuitem"
                                >
                                    {link.name}
                                </a>
                            </li>
                    ))}
                </ul>
            </div>

            <div class="navbar-end gap-4 mt-2">
                <a
                        href="#contacto"
                        class="flex btn btn-primary w-auto "
                        aria-label="Solicitar presupuesto"
                >
                    Pedir presupuesto
                </a>
            </div>


        </nav>
    </div>
    <div>
        <div class="h-[10px] bg-gradient-to-r from-latorre-primary from-0% to-latorre-base to-60% md:hidden" aria-hidden="true"></div>
        <div class="h-[10px] bg-gradient-to-r from-latorre-primary from-0% to-latorre-base to-30% hidden md:block" aria-hidden="true"></div>
    </div>

    <div>
        <div class="h-[10px] bg-gradient-to-r from-latorre-primary from-0% to-latorre-base to-70% md:hidden" aria-hidden="true"></div>
        <div class="h-[10px] bg-gradient-to-r from-latorre-primary from-0% to-latorre-base to-40% hidden md:block" aria-hidden="true"></div>
    </div>

    <div>
        <div class="h-[10px] bg-gradient-to-r from-latorre-primary from-0% to-latorre-base to-80% md:hidden" aria-hidden="true"></div>
        <div class="h-[10px] bg-gradient-to-r from-latorre-primary from-0% to-latorre-base to-50% hidden md:block" aria-hidden="true"></div>
    </div>

</header>
