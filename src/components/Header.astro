---

const navLinks = [
    {name: 'Inicio', href: '/'},
    {name: 'Servicios', href: '#servicios'},
    {name: 'Cobertura', href: '#cobertura'},
    {name: 'Contacto', href: '#contacto'},
];
---

<header
        class="bg-latorre-base sticky top-0 z-50 shadow-[0_2px_4px_0_rgba(0,0,0,0.05)]"
        role="banner"
>
    <div class="container mx-auto px-4">
        <nav
                class="navbar min-h-16"
                role="navigation"
                aria-label="Navegación principal"
        >

            <div class="navbar-start">
                <a
                        href="/"
                        class="font-stencil text-2xl text-latorre-primary"
                        aria-label="Lavandería La Torre - Ir al inicio"
                >
                    <span>LA TORRE</span>
                </a>
            </div>

            <div class="navbar-center hidden lg:flex">
                <ul class="menu menu-horizontal gap-2" role="menubar">
                    {navLinks.map((link) => (
                            <li role="none">
                                <a
                                        href={link.href}
                                        class="text-latorre-text hover:text-latorre-primary transition-colors"
                                        role="menuitem"
                                >
                                    {link.name}
                                </a>
                            </li>
                    ))}
                </ul>
            </div>

            <div class="navbar-end gap-4">
                <a
                        href="#contacto"
                        class="btn btn-dash btn-primary hidden lg:inline-flex"
                        aria-label="Solicitar presupuesto"
                >
                    Pedir presupuesto
                </a>

                <div class="dropdown dropdown-end lg:hidden">
                    <label
                            tabindex="0"
                            class="btn btn-ghost"
                            aria-label="Abrir menú de navegación"
                            aria-expanded="false"
                            aria-controls="mobile-menu"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                        </svg>
                    </label>
                    <ul
                            id="mobile-menu"
                            tabindex="0"
                            class="dropdown-content menu bg-latorre-base rounded-box shadow-lg w-52 p-2 mt-2"
                            role="menu"
                            aria-label="Menú móvil"
                    >
                        {navLinks.map((link) => (
                                <li role="none">
                                    <a
                                            href={link.href}
                                            class="text-latorre-text"
                                            role="menuitem"
                                    >
                                        {link.name}
                                    </a>
                                </li>
                        ))}
                        <li role="none" class="mt-2">
                            <a
                                    href="#contacto"
                                    class="btn btn-dash btn-primary hidden lg:inline-flex"
                                    aria-label="Solicitar presupuesto"
                            >
                                Pedir presupuesto
                            </a>
                        </li>
                    </ul>
                </div>
            </div>

        </nav>
    </div>
    <div class="h-[10px] bg-gradient-to-r from-latorre-primary from-0% to-latorre-base to-30%" aria-hidden="true"></div>
</header>
