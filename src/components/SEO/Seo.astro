---
import {business} from "../../data/business";
interface Props {
    title?: string;
    description?: string;
    canonical?: string;
    image?: string;
    type?: "website" | "article";
    noindex?: boolean;
}

const {
    title = business.name,
    description = business.description,
    canonical = Astro.url.href,
    image = business.ogImage,
    type = "website",
    noindex = false,
} = Astro.props;

const fullTitle = title === business.name
    ? `${business.name} | ${business.slogan}`
    : `${title} | ${business.name}`;

const absoluteImageUrl = new URL(image, business.url).href;
const absoluteLogoUrl = new URL(business.logo, business.url).href;

const schemaData = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "LocalBusiness",
            "@id": `${business.url}/#business`,
            "name": business.name,
            "alternateName": business.alternateName,
            "description": business.description,
            "url": business.url,
            "logo": {
                "@type": "ImageObject",
                "url": absoluteLogoUrl,
            },
            "image": absoluteImageUrl,
            "telephone": business.phone,
            "email": business.email,
            "address": {
                "@type": "PostalAddress",
                "streetAddress": business.address.street,
                "addressLocality": business.address.locality,
                "postalCode": business.address.postalCode,
                "addressRegion": business.address.region,
                "addressCountry": business.address.country,
            },
            "geo": {
                "@type": "GeoCoordinates",
                "latitude": business.geo.latitude,
                "longitude": business.geo.longitude,
            },
            "areaServed": business.areaServed.map(city => ({
                "@type": "City",
                "name": city,
            })),
            "openingHoursSpecification": business.openingHours.map(schedule => ({
                "@type": "OpeningHoursSpecification",
                "dayOfWeek": schedule.days,
                "opens": schedule.opens,
                "closes": schedule.closes,
            })),
            "priceRange": business.priceRange,
            "currenciesAccepted": business.currenciesAccepted,
            "paymentAccepted": business.paymentAccepted.join(", "),
            "hasOfferCatalog": {
                "@type": "OfferCatalog",
                "name": "Servicios de Lavandería",
                "itemListElement": business.services.map(service => ({
                    "@type": "Offer",
                    "itemOffered": {
                        "@type": "Service",
                        "name": service.name,
                        "description": service.description,
                    },
                })),
            },
            "aggregateRating": {
                "@type": "AggregateRating",
                "ratingValue": business.rating.value,
                "reviewCount": business.rating.count,
            },
            "sameAs": Object.values(business.social),
        },
        {
            "@type": "WebSite",
            "@id": `${business.url}/#website`,
            "url": business.url,
            "name": business.name,
            "publisher": {
                "@id": `${business.url}/#business`,
            },
            "inLanguage": "es-ES",
        },
        {
            "@type": "WebPage",
            "@id": canonical,
            "url": canonical,
            "name": fullTitle,
            "description": description,
            "isPartOf": {
                "@id": `${business.url}/#website`,
            },
            "about": {
                "@id": `${business.url}/#business`,
            },
            "inLanguage": "es-ES",
        },
        ...(business.faqs?.length ? [{
            "@type": "FAQPage",
            "@id": `${business.url}/#faq`,
            "mainEntity": business.faqs.map(faq => ({
                "@type": "Question",
                "name": faq.question,
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": faq.answer
                }
            }))
        }] : []),
    ],
};
---

<title>{fullTitle}</title>
<meta name="description" content={description}/>
<link rel="canonical" href={canonical}/>
{noindex &&
<meta name="robots" content="noindex, nofollow"/>}

<!-- Idioma -->
<meta property="og:locale" content="es_ES"/>
<link rel="alternate" hreflang="es" href={canonical}/>

<meta property="og:type" content={type}/>
<meta property="og:site_name" content={business.name}/>
<meta property="og:title" content={fullTitle}/>
<meta property="og:description" content={description}/>
<meta property="og:url" content={canonical}/>
<meta property="og:image" content={absoluteImageUrl}/>
<meta property="og:image:width" content="1200"/>
<meta property="og:image:height" content="630"/>

<meta name="twitter:card" content="summary_large_image"/>
<meta name="twitter:title" content={fullTitle}/>
<meta name="twitter:description" content={description}/>
<meta name="twitter:image" content={absoluteImageUrl}/>

<meta name="geo.region" content={`${business.address.country}-${business.address.locality.substring(0, 2).toUpperCase()}`}/>
<meta name="geo.placename" content={business.address.locality}/>
<meta name="geo.position" content={`${business.geo.latitude};${business.geo.longitude}`}/>
<meta name="ICBM" content={`${business.geo.latitude}, ${business.geo.longitude}`}/>

<meta name="author" content={business.name}/>

<script type="application/ld+json" set:html={JSON.stringify(schemaData)}/>
