---
import {business} from "../data/business";
---

<section id="zonas" class="py-10 bg-latorre-background">
    <div class="container mx-auto px-4">
        <div class="text-center mb-4 w-full flex">
            <h2
                    id="contacto-titulo"
                    class="font-stencil text-3xl md:text-4xl lg:text-5xl text-latorre-text mb-4"
            >
                Zonas de Servicio
            </h2>
        </div>

        <div class="grid lg:grid-cols-3 gap-8">
            <div class="space-y-3">
                <div class="grid grid-cols-2 gap-3">
                    {business.areaServed.map((zona) => (
                            <div class="flex items-center gap-3 p-3 bg-base-200 rounded-lg">
                                <div class="w-3 h-3 rounded-full bg-primary"></div>
                                <span>{zona}</span>
                            </div>
                    ))}
                </div>

            </div>
            <div class="lg:col-span-2">
                <div id="map" class="w-full h-96 rounded-2xl shadow-lg pointer-events-none"></div>
            </div>
        </div>
    </div>

    <link href="https://unpkg.com/maplibre-gl@4.1.2/dist/maplibre-gl.css" rel="stylesheet"/>

    <script>
        import maplibregl, {GeoJSONSourceSpecification} from 'maplibre-gl';

        const map = new maplibregl.Map({
            container: 'map',
            style: 'https://basemaps.cartocdn.com/gl/positron-gl-style/style.json',
            center: [-4.5612, 36.6641],
            zoom:9.5
        });

        // Zona de servicio ajustada a los municipios
        const zonaServicio = {
            type: 'Feature',
            geometry: {
                type: 'Polygon',
                coordinates: [
                    []
                ]
            }
        };

        map.on('load', () => {
            map.addSource('zona-servicio', {
                type: 'geojson',
                data: zonaServicio
            } as GeoJSONSourceSpecification);

            new maplibregl.Marker({color: '#D4AF37'})
                .setLngLat([-4.5612, 36.6641])
                .setPopup(new maplibregl.Popup().setHTML('<strong>Lavandería La Torre</strong>'))
                .addTo(map);

// Markers municipios
            const municipios = [
                {nombre: 'Málaga', coords: [-4.4214, 36.7213]},
                {nombre: 'Torremolinos', coords: [-4.4999, 36.6242]},
                {nombre: 'Fuengirola', coords: [-4.6243, 36.5441]},
                {nombre: 'Cártama', coords: [-4.6332, 36.7103]},
                {nombre: 'Churriana', coords: [-4.4985, 36.6667]},
                {nombre: 'Benalmádena', coords: [-4.5169, 36.5987]},
            ];

            municipios.forEach(muni => {
                new maplibregl.Marker({color: '#0780FE'})
                    .setLngLat(muni.coords)
                    .setPopup(new maplibregl.Popup().setHTML(`<strong>${muni.nombre}</strong>`))
                    .addTo(map);
            });
        });
    </script>
</section>



