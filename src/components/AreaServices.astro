---
import {business} from "../data/business";
import Title from "./childComponents/Title.astro";
---

<section id="zonas" class="py-10 bg-latorre-background px-[5%]">
    <div class="container mx-auto px-4">

        <Title text=" Zonas de Servicio" id="cobertura-titulo"/>

        <div class="grid lg:grid-cols-3 gap-8">
            <div class="space-y-3">
                <div class="grid grid-cols-2 gap-3">
                    {business.areaServed.map((zona) => (
                            <div class="flex items-center gap-3 p-3 rounded-lg">
                                <div class="w-3 h-3 rounded-full bg-gradient-to-br from-primary to-primary/60"></div>
                                <span>
                                    {zona.name}
                                    {zona.note && <span class="text-xs text-base-content/50 ml-1">{zona.note}</span>}
                                </span>
                            </div>
                    ))}
                </div>

            </div>
            <div class="lg:col-span-2">
                <div id="map" class="w-full h-96 rounded-2xl shadow-lg pointer-events-none"></div>
            </div>
        </div>
    </div>

    <link href="https://unpkg.com/maplibre-gl@4.1.2/dist/maplibre-gl.css" rel="stylesheet"/>
    <script>
        import maplibregl, {type GeoJSONSourceSpecification, type LayerSpecification} from 'maplibre-gl';

        const map = new maplibregl.Map({
            container: 'map',
            style: 'https://basemaps.cartocdn.com/gl/positron-gl-style/style.json',
            center: [-4.5612, 36.6641],
            zoom: 9.5,
            attributionControl: false
        });

        map.addControl(new maplibregl.AttributionControl({
            compact: true
        }), 'bottom-right');

        map.on('load', () => {

            const attrib = document.querySelector('#map .maplibregl-ctrl-attrib') as HTMLElement;
            attrib?.classList.remove('maplibregl-compact-show');

            if (map.getLayer('water')) {
                map.setPaintProperty('water', 'fill-color', '#e8e8e8');
                map.setPaintProperty('water', 'fill-opacity', 1);
            }

            const heatZones = {
                type: 'FeatureCollection',
                features: [
                    {type: 'Feature', geometry: {type: 'Point', coordinates: [-4.4214, 36.7213]}, properties: {intensity: 1}},
                    {type: 'Feature', geometry: {type: 'Point', coordinates: [-4.4999, 36.6242]}, properties: {intensity: 0.8}},
                    {type: 'Feature', geometry: {type: 'Point', coordinates: [-4.6243, 36.5441]}, properties: {intensity: 0.7}},
                    {type: 'Feature', geometry: {type: 'Point', coordinates: [-4.5612, 36.6641]}, properties: {intensity: 1}},
                    {type: 'Feature', geometry: {type: 'Point', coordinates: [-4.6332, 36.7103]}, properties: {intensity: 0.6}},
                    {type: 'Feature', geometry: {type: 'Point', coordinates: [-4.4985, 36.6667]}, properties: {intensity: 0.7}},
                ]
            };

            map.addSource('heat-zones', {
                type: 'geojson',
                data: heatZones
            } as GeoJSONSourceSpecification);

            map.addLayer({
                id: 'heat-layer',
                type: 'circle',
                source: 'heat-zones',
                paint: {
                    'circle-radius': ['interpolate', ['linear'], ['zoom'], 8, 80, 12, 200],
                    'circle-color': '#0780FE',
                    'circle-opacity': ['*', 0.25, ['get', 'intensity']],
                    'circle-blur': 1
                }
            } as LayerSpecification, 'water');

            map.addLayer({
                id: 'heat-layer-core',
                type: 'circle',
                source: 'heat-zones',
                paint: {
                    'circle-radius': ['interpolate', ['linear'], ['zoom'], 8, 30, 12, 80],
                    'circle-color': '#0780FE',
                    'circle-opacity': ['*', 0.4, ['get', 'intensity']],
                    'circle-blur': 0.8
                }
            } as LayerSpecification, 'water');
            let pulse = 0;
            const animateHeat = () => {
                pulse = (pulse + 0.02) % (Math.PI * 2);
                const scale = 1 + Math.sin(pulse) * 0.15; // oscila entre 0.85 y 1.15
                const opacity = 0.25 + Math.sin(pulse) * 0.08; // oscila entre 0.17 y 0.33

                map.setPaintProperty('heat-layer', 'circle-radius',
                    ['interpolate', ['linear'], ['zoom'], 8, 80 * scale, 12, 200 * scale]
                );
                map.setPaintProperty('heat-layer', 'circle-opacity',
                    ['*', opacity, ['get', 'intensity']]
                );

                requestAnimationFrame(animateHeat);
            };

            animateHeat();
        });


    </script>
</section>



